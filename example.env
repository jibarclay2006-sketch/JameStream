# Required for movie and TV metadata. Use a TMDB API read-access token.
VITE_TMDB_READ_API_KEY=

# Public URL for this deployment (no trailing slash).
VITE_APP_DOMAIN=http://localhost:5173

# Use true when your host rewrites unknown routes to /index.html.
VITE_NORMAL_ROUTER=false
VITE_BASE_URL=/
VITE_PWA_ENABLED=true
VITE_OPENSEARCH_ENABLED=false

# Optional, comma-separated proxy URLs that you operate or trust (no trailing slash).
VITE_CORS_PROXY_URL=
VITE_M3U8_PROXY_URL=

# Optional account-sync backend URL(s), comma-separated.
VITE_BACKEND_URL=

# Show connection setup when a default proxy is not configured.
VITE_HAS_ONBOARDING=true
VITE_HIDE_PROXY_ONBOARDING=false
VITE_ONBOARDING_CHROME_EXTENSION_INSTALL_LINK=
VITE_ONBOARDING_FIREFOX_EXTENSION_INSTALL_LINK=
VITE_ONBOARDING_PROXY_INSTALL_LINK=

# Optional playback and provider features.
VITE_ALLOW_AUTOPLAY=false
VITE_ALLOW_FEBBOX_KEY=false
VITE_ALLOW_DEBRID_KEY=false
VITE_DISALLOWED_IDS=
VITE_CDN_REPLACEMENTS=

# Optional account integrations.
VITE_USE_TRAKT=false
VITE_TRAKT_CLIENT_ID=
VITE_TRAKT_CLIENT_SECRET=
VITE_TRAKT_REDIRECT_URI=
VITE_USE_SIMKL=false
VITE_SIMKL_CLIENT_ID=
VITE_SIMKL_CLIENT_SECRET=
VITE_SIMKL_REDIRECT_URI=

# Optional operator information.
VITE_DMCA_EMAIL=
VITE_BANNER_MESSAGE=
VITE_BANNER_ID=

# Docker host port.
JAMESTREAM_PORT=8080
